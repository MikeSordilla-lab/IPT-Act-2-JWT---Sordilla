{
  "name": "ipt/jwt-auth-api",
  "description": "Simple JWT authentication API for IPT Activity 2",
  "type": "project",
  "require": {
    "php": "^8.0",
    "ext-mysqli": "*",
    "firebase/php-jwt": "*",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}
